# .env.example

# Environment variables required for the project

# Database configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_username
DB_PASSWORD=your_password
DB_NAME=your_database_name

# Application settings
APP_ENV=development
APP_DEBUG=true
APP_KEY=base64:your_base64_encoded_key

# Other services
API_KEY=your_api_key

# Add any additional environment variables needed for your application here
