function SchoolDetails(\{ data \}) \{\
  const [insights, setInsights] = useState('');\
  const [loading, setLoading] = useState(false);\
\
  const generateInsights = async () => \{\
    setLoading(true);\
    try \{\
      const prompt = `Analyze this school's data and provide an engaging 2-3 sentence summary for a parent. Consider its size ($\{data['Size Metric']\}), type ($\{data['Business Type']\}), and relative spending ($\{data['Est. Spend Mid (\'80)']\}). School Name: $\{data['Organization Name']\}.`;\
      const result = await fetchGeminiContent(prompt);\
      setInsights(result);\
    \} catch (err) \{\
      setInsights('Failed to generate insights. Please try again.');\
    \} finally \{\
      setLoading(false);\
    \}\
  \};\
\
  return (\
    <div className="bg-white border border-gray-200 rounded-lg p-4 my-2 shadow-sm">\
      <h4 className="font-bold text-black text-lg border-b border-gray-100 pb-2 mb-3">\{data['Organization Name'] || 'Unknown School'\}</h4>\
      <ul className="space-y-2 text-sm text-gray-700 mb-4">\
        <li><span className="font-semibold text-gray-900 block text-xs uppercase tracking-wider text-gray-500">Size</span> \{data['Size Metric'] || 'N/A'\}</li>\
        <li><span className="font-semibold text-gray-900 block text-xs uppercase tracking-wider text-gray-500">Phone No.</span> \{data['Phone No.'] || 'N/A'\}</li>\
        <li><span className="font-semibold text-gray-900 block text-xs uppercase tracking-wider text-gray-500">Principal</span> \{data['Principal Name'] || 'N/A'\}</li>\
        <li><span className="font-semibold text-gray-900 block text-xs uppercase tracking-wider text-gray-500">Eircode</span> \{data.Eircode || 'N/A'\}</li>\
        <li><span className="font-semibold text-gray-900 block text-xs uppercase tracking-wider text-gray-500">Email</span> \
          \{data.Email ? <a href=\{`mailto:$\{data.Email\}`\} className="text-red-600 hover:underline">\{data.Email\}</a> : 'N/A'\}\
        </li>\
      </ul>\
\
      \{/* AI Insights Section */\}\
      <div className="border-t border-gray-100 pt-3">\
        \{!insights && !loading && (\
          <button \
            onClick=\{generateInsights\}\
            className="w-full bg-gray-50 hover:bg-red-50 text-red-600 border border-gray-200 hover:border-red-200 rounded-md py-2 text-sm font-medium transition-all"\
          >\
            \uc0\u10024  Generate AI Insights\
          </button>\
        )\}\
        \{loading && (\
          <div className="w-full bg-gray-50 text-red-500 border border-gray-100 rounded-md py-2 text-sm font-medium text-center animate-pulse">\
            \uc0\u10024  Generating insights...\
          </div>\
        )\}\
        \{insights && (\
          <div className="bg-red-50 rounded-md p-3 border border-red-100">\
            <h5 className="text-red-700 font-bold text-xs uppercase tracking-wider mb-1 flex items-center gap-1">\uc0\u10024  AI Insight</h5>\
            <p className="text-sm text-gray-800 leading-relaxed">\{insights\}</p>\
          </div>\
        )\}\
      </div>\
    </div>\
  );\
\}\
