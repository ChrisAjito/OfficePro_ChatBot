function SuggestionList(\{ suggestions, onSelect \}) \{\
  if (!suggestions || suggestions.length === 0) return null;\
\
  return (\
    <div className="absolute bottom-full left-0 w-full bg-white border border-gray-200 rounded-t-lg shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.1)] max-h-48 overflow-y-auto z-10">\
      <ul className="py-1">\
        \{suggestions.map((suggestion, idx) => (\
          <li \
            key=\{idx\}\
            onClick=\{() => onSelect(suggestion)\}\
            className="px-4 py-2 hover:bg-red-50 text-sm text-gray-800 cursor-pointer border-b border-gray-50 last:border-0 transition-colors"\
          >\
            \{suggestion\}\
          </li>\
        ))\}\
      </ul>\
    </div>\
  );\
\}\
