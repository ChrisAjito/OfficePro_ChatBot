    <div \
      onClick=\{() => onClick(data['Organization Name'])\}\
      className="bg-white border border-gray-200 rounded-lg p-3 my-2 shadow-sm cursor-pointer hover:border-red-500 hover:shadow-md transition-all active:scale-[0.98]"\
